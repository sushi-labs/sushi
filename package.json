{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm clean && pnpm build:cjs && pnpm build:esm && pnpm build:types",
    "build:cjs": "tsc -p tsconfig.build.cjs.json && printf '{\"type\":\"commonjs\"}' > ./src/_cjs/package.json",
    "build:esm": "tsc -p tsconfig.build.esm.json && printf '{\"type\": \"module\",\"sideEffects\":false}' > ./src/_esm/package.json",
    "build:types": "tsc -p tsconfig.build.types.json",
    "changeset:prepublish": "node scripts/prepublish-only.ts && node scripts/update-version.ts && pnpm build",
    "changeset:publish": "pnpm changeset:prepublish && changeset publish",
    "changeset:version": "changeset version && pnpm install --lockfile-only && pnpm format",
    "deps": "pnpx taze -r",
    "clean": "rm -rf *.tsbuildinfo src/*.tsbuildinfo src/_esm src/_cjs src/_types",
    "docs:dev": "pnpm --filter site dev",
    "docs:build": "pnpm --filter site build",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "lint:dryrun": "biome check .",
    "lint:repo": "sherif",
    "lint:unused": "pnpm clean && knip",
    "preinstall": "only-allow pnpm",
    "prepublishOnly": "node scripts/prepublish-only.ts",
    "test": "vitest -c ./test/vitest.config.ts dev",
    "test:ci": "CI=true vitest -c ./test/vitest.config.ts --coverage --retry=3 --bail=1",
    "test:cov": "vitest dev -c ./test/vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@types/node": "25.9.3",
    "@typescript/native": "catalog:",
    "@viem/anvil": "0.0.10",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "knip": "6.26.0",
    "only-allow": "1.2.1",
    "sherif": "1.13.0",
    "typescript": "catalog:",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "react-copy-to-clipboard>react": "19",
        "react-debounce-input>react": "19",
        "react-inspector>react": "19"
      }
    }
  },
  "knip": {
    "ignoreBinaries": [
      "printf"
    ],
    "ignoreIssues": {
      "src/evm/config/features/{merkl,pancakeswap-v2,pancakeswap-v3,sushiswap,sushiswap-v2,sushiswap-v3,uniswap-v2,uniswap-v3}.ts": [
        "duplicates"
      ]
    },
    "ignoreWorkspaces": [
      "examples/**",
      "test"
    ],
    "vitest": {
      "config": [
        "test/vitest.config.ts"
      ],
      "entry": [
        "**/*.{bench,bench-d,test,test-d,spec}.?(c|m)[jt]s?(x)"
      ]
    },
    "compilers": {
      "mdx": true
    },
    "workspaces": {
      ".": {
        "project": "scripts/*.ts"
      },
      "src": {
        "entry": [
          "{generic,evm,mvm,stellar,svm}/index.ts!"
        ],
        "ignore": []
      },
      "site": {
        "entry": [
          "vocs.config.ts",
          "pages/**/*.mdx"
        ],
        "project": [
          "**/*.ts",
          "**/*.tsx",
          "**/*.mdx"
        ]
      }
    }
  }
}
